# 外部阶段二运行时示例环境变量

# 按 runtime/stage2/api_config.py 当前默认槽位填写
VOLCENGINE_API_KEY=

# 如果同一 provider 有多 key，可填写逗号分隔的 key pool
# VOLCENGINE_API_KEYS=key_a,key_b

# 若你把阶段二槽位切到其他 provider，再补对应 key
# SILICONFLOW_API_KEY=
# OPENROUTER_API_KEY=
# ALIYUN_API_KEY=
# SILICONFLOW_API_KEYS=
# OPENROUTER_API_KEYS=
# ALIYUN_API_KEYS=
