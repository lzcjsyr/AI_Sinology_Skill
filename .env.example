# 必填：provider key 预留位
SILICONFLOW_API_KEY=
OPENROUTER_API_KEY=
VOLCENGINE_API_KEY=
ALIYUN_API_KEY=

# 可选：同一 provider 多 key（逗号分隔），用于 LiteLLM Router 负载均衡
# 示例：VOLCENGINE_API_KEYS=key_a,key_b
# SILICONFLOW_API_KEYS=
# OPENROUTER_API_KEYS=
# VOLCENGINE_API_KEYS=
# ALIYUN_API_KEYS=

# 可选：全局运行参数
# REQUEST_TIMEOUT=180
# MAX_RETRIES=3
# RETRY_BACKOFF_SECONDS=2
# MAX_FRAGMENTS=
# STAGE2_LLM1_CONCURRENCY=
# STAGE2_LLM2_CONCURRENCY=
# STAGE2_ARBITRATION_CONCURRENCY=
# STAGE2_SYNC_HEADROOM=0.85
# STAGE2_SYNC_MAX_AHEAD=128
# STAGE2_SYNC_MODE=lowest_shared
# STAGE2_SCREENING_BATCH_MAX_CHARS=300
# STAGE2_FRAGMENT_MAX_ATTEMPTS=3
# STAGE2_MAX_EMPTY_RETRIES=2
# STAGE2_LLM1_RPM=30000
# STAGE2_LLM1_TPM=10000000
# STAGE2_LLM2_RPM=30000
# STAGE2_LLM2_TPM=5000000
# STAGE2_LLM3_RPM=30000
# STAGE2_LLM3_TPM=5000000
